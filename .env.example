# Segmentation Copilot — environment variables.
#
# Every setting is namespaced under SCOPILOT_; nested settings use the
# `__` delimiter, e.g. SCOPILOT_DB__URL becomes settings.db.url.
# Defaults live in src/segmentation_copilot/config.py.

# --- General ---------------------------------------------------------------
SCOPILOT_ENVIRONMENT=dev               # dev | staging | prod
SCOPILOT_LOG_LEVEL=INFO
SCOPILOT_LOG_FORMAT=text               # text | json
SCOPILOT_DEFAULT_TENANT_ID=default

# --- Database --------------------------------------------------------------
# Dev default is SQLite via aiosqlite. Prod uses asyncpg.
# SCOPILOT_DB__URL=postgresql+asyncpg://user:pass@postgres:5432/scopilot
SCOPILOT_DB__URL=sqlite+aiosqlite:///data/segmentation.db
# SCOPILOT_DB__SYNC_URL is auto-derived if unset; only override for Alembic
# against an exotic driver.
# SCOPILOT_DB__SYNC_URL=postgresql+psycopg2://user:pass@postgres:5432/scopilot
SCOPILOT_DB__ECHO=false

# --- Redis (event bus + cache) ---------------------------------------------
# Set to `memory://` to use the in-process bus (dev / tests).
SCOPILOT_REDIS__URL=redis://localhost:6379/0
SCOPILOT_REDIS__STREAM_MAX_LEN=10000

# --- Anthropic -------------------------------------------------------------
SCOPILOT_ANTHROPIC__API_KEY=
SCOPILOT_ANTHROPIC__MODEL=claude-opus-4-7
SCOPILOT_ANTHROPIC__MAX_TOKENS=4096

# --- Threat intelligence (Phase 5) -----------------------------------------
SCOPILOT_THREAT__ABUSEIPDB_API_KEY=
SCOPILOT_THREAT__OTX_API_KEY=
SCOPILOT_THREAT__VIRUSTOTAL_API_KEY=
SCOPILOT_THREAT__TALOS_ENABLED=false     # opt-in; no free official API
SCOPILOT_THREAT__MALICIOUS_SCORE_THRESHOLD=50

# --- Scheduler / worker ----------------------------------------------------
SCOPILOT_SCHED__SCAN_INTERVAL_MINUTES=15
SCOPILOT_SCHED__CLASSIFICATION_CACHE_DAYS=7
SCOPILOT_SCHED__FLOW_BATCH_SIZE=50
SCOPILOT_SCHED__DAILY_ANTHROPIC_SPEND_USD_CAP=50.0
SCOPILOT_SCHED__LEADER_LOCK_TTL_SECONDS=30
SCOPILOT_SCHED__LEADER_REFRESH_SECONDS=10

# --- FastAPI service (Phase 2) ---------------------------------------------
SCOPILOT_API__HOST=0.0.0.0
SCOPILOT_API__PORT=8000
SCOPILOT_API__REQUIRE_AUTH=true
# JSON array of accepted bearer tokens (rotate via secrets manager in prod).
# SCOPILOT_API__API_KEYS=["replace-me-in-prod"]
# SCOPILOT_API__CORS_ORIGINS=["https://ui.example.com"]

# --- WebEx bot -------------------------------------------------------------
# Required for the bot to send/receive messages and post adaptive cards.
# Leave blank to disable the WebEx sink — proposals will still be created
# and approvable via the REST API + Streamlit, just not in WebEx.
SCOPILOT_WEBEX__BOT_ACCESS_TOKEN=
SCOPILOT_WEBEX__WEBHOOK_SECRET=             # HMAC secret WebEx signs with
SCOPILOT_WEBEX__OPERATORS_ROOM_ID=          # WebEx room id for alerts
SCOPILOT_WEBEX__PROPOSAL_EXPIRY_HOURS=24    # auto-expire stale proposals
